# ========== SERVER ==========
PORT=8080
ENV=development
CORS_ORIGIN=http://localhost:5173

# ========== DATABASE ==========
DATABASE_URL=postgres://postgres:123@localhost:5432/humanguard?sslmode=disable

# ========== AUTH ==========
JWT_SECRET=super-secret-key-change-in-production

# ========== STORAGE ==========
STORAGE_TYPE=local
UPLOAD_DIR=./data/uploads

# ========== MINIO (опционально, если STORAGE_TYPE=minio) ==========
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=humanguard
MINIO_USE_SSL=false

# ========== OAUTH - KEYCLOAK ==========
OAUTH_CLIENT_ID=humanguard
OAUTH_CLIENT_SECRET=your-keycloak-secret
KEYCLOAK_REDIRECT_URL=http://localhost:8080/api/auth/keycloak/callback

# ========== OAUTH - GOOGLE ==========
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_GOOGLE_REDIRECT_URL=http://localhost:8080/api/auth/google/callback

# ========== OAUTH - GITHUB ==========
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
OAUTH_GITHUB_REDIRECT_URL=http://localhost:8080/api/auth/github/callback

# ========== FRONTEND (для редиректа после OAuth) ==========
FRONTEND_URL=http://localhost:5173

# ========== DEFAULT ADMIN (автосоздание при первом запуске) ==========
DEFAULT_ADMIN_EMAIL=admin@localhost.com
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_ADMIN_NAME=System Admin